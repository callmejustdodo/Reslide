{
  "name": "@reslide/cli",
  "version": "0.0.1",
  "description": "CLI commands and Vite plugin for Reslide",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reslide": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "files": ["dist", "client.d.ts"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "@reslide/core": "workspace:*",
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@reslide/core": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
